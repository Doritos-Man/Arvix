[general]
framerate = 30
bars = 32

[input]
method = pulse
source = auto

[output]
method = raw
raw_target = /dev/shm/cava.fifo
data_format = ascii
ascii_max_range = 100
bar_delimiter = 59

[smoothing]
integral = 70
monstercat = 1
waves = 1
gravity = 100
ignore = 0

[eq]
1 = 1
2 = 1
3 = 1
4 = 1
5 = 1